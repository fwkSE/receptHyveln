# Copy to .env on the VPS (never commit .env).
# Replace example.com with your public hostname.

IMAGE=ghcr.io/OWNER/REPO:latest

ALLOWED_HOSTS=recept.example.com
ALLOWED_ORIGINS=https://recept.example.com
TRUST_PROXY_HEADERS=true
OPENAPI_DOCS=false

# Optional tuning for small VPS hosts
# EXTRACT_TIMEOUT=15
# MAX_CONCURRENT_FETCHES=3
